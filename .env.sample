# ─────────────────────────────────────────────────────────────────────
# Maison · environment template
# ─────────────────────────────────────────────────────────────────────
# Local development:
#   cp .env.sample .env.local         (or apps/web/.env.local)
#   Fill in the values you need; commit nothing.
#
# Deployment (Vercel, Fly, etc.):
#   Set every variable below in the platform's secret store.
#   Do NOT commit a populated .env to this repo.
#
# ─────────────────────────────────────────────────────────────────────

# ───── Database ─────
# Supabase Postgres pooled connection string (use the pooler URL for
# serverless deployments; direct URL for migrations).
DATABASE_URL=

# ───── Better-Auth ─────
# Required. 32-byte secret used to sign session cookies.
#   openssl rand -hex 32
BETTER_AUTH_SECRET=

# Required. Public origin of the deployed app — used to build OAuth
# redirect URIs and absolute callback URLs.
#   Local:      http://localhost:3000
#   Preview:    https://<branch>.<project>.vercel.app
#   Production: https://maison.example.com
BETTER_AUTH_URL=http://localhost:3000

# ───── Social providers (all optional) ─────
# Each provider is registered only when both ID and SECRET are present.
# Leave a pair blank to hide that button on the /signin page.

# Google — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: $BETTER_AUTH_URL/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook — https://developers.facebook.com/apps
# Valid OAuth Redirect URI: $BETTER_AUTH_URL/api/auth/callback/facebook
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# LINE Login — https://developers.line.biz/console/
# Callback URL: $BETTER_AUTH_URL/api/auth/callback/line
LINE_CLIENT_ID=
LINE_CLIENT_SECRET=

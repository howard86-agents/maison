// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

enum UserRole {
  USER
  STAFF
  ADMIN
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String?        @unique
  emailVerified Boolean        @default(false)
  image         String?
  isAnonymous   Boolean?       @default(false)
  role          UserRole       @default(USER)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  proxyRequests ProxyRequest[]
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
  @@index([identifier])
}

enum OrderStatus {
  PENDING
  PAID
  SOURCING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum ProxyRequestStatus {
  SUBMITTED
  QUOTED
  ACCEPTED
  SOURCING
  READY
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

model FxRate {
  id            String   @id @default(cuid())
  baseCurrency  String
  quoteCurrency String
  rate          Decimal  @db.Decimal(20, 10)
  source        String
  fetchedAt     DateTime @default(now())

  @@unique([baseCurrency, quoteCurrency, source])
  @@index([baseCurrency, quoteCurrency])
  @@index([fetchedAt])
}

model Product {
  id          String      @id @default(cuid())
  name        String
  brand       String?
  category    String?
  description String?
  basePrice   Decimal     @db.Decimal(12, 2)
  currency    String      @default("TWD")
  imageUrls   String[]
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]

  @@index([brand])
  @@index([category])
  @@index([isActive])
}

model Order {
  id              String      @id @default(cuid())
  userId          String
  status          OrderStatus @default(PENDING)
  subtotalAmount  Decimal     @db.Decimal(12, 2)
  totalAmount     Decimal     @db.Decimal(12, 2)
  currency        String      @default("TWD")
  shippingAddress Json?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  user            User        @relation(fields: [userId], references: [id])
  items           OrderItem[]
  payments        Payment[]

  @@index([userId])
  @@index([status])
}

model Payment {
  id             String        @id @default(cuid())
  orderId        String
  provider       String
  providerTxId   String?
  amount         Decimal       @db.Decimal(12, 2)
  currency       String        @default("TWD")
  status         PaymentStatus @default(PENDING)
  webhookPayload Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  order          Order         @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([providerTxId])
  @@index([status])
}

model OrderItem {
  id             String        @id @default(cuid())
  orderId        String
  productId      String?
  proxyRequestId String?       @unique
  quantity       Int           @default(1)
  unitPrice      Decimal       @db.Decimal(12, 2)
  currency       String        @default("TWD")
  snapshot       Json
  order          Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        Product?      @relation(fields: [productId], references: [id])
  proxyRequest   ProxyRequest? @relation(fields: [proxyRequestId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model ProxyRequest {
  id                 String             @id @default(cuid())
  userId             String
  status             ProxyRequestStatus @default(SUBMITTED)
  description        String
  targetBrand        String?
  targetModel        String?
  referenceImageUrls String[]
  quotedAmount       Decimal?           @db.Decimal(12, 2)
  currency           String             @default("TWD")
  staffNotes         String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  user               User               @relation(fields: [userId], references: [id])
  orderItem          OrderItem?

  @@index([userId])
  @@index([status])
}
